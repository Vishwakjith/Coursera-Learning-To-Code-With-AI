{
  "manifest_version": 3,
  "name": "Shopping List Saver",
  "version": "1.0",
  "description": "Save the current tab URL to a categorized shopping list.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Shopping List",
    "default_icon": {
        "16": "assets/icon16.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ]
}
